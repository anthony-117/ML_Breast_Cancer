feed_forward <- function(NN, start_index , batch.size){
y.fw <- list()
weights.nb <- length(NN$weights)
for( i in 1:batch.size){
y.fw[[1]] <- NN$X[i,]
for( j in 1:length(NN$layers)){
v <- c(-1, y.fw[[j]]) %*% NN$weights[[j]]
y.fw[[j+1]] <- sigmoid(v)
}
y.hat[i] <- y.fw[[length(y.fw)]]
}
return(y.hat)
}
