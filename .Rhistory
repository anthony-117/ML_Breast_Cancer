update_weights <- function(env, new_value) {
env$weights <- new_value  # Modifies directly within the environment
}
NN <- new.env()  # Create an environment
NN$weights <- numeric(1, 3, 3)  # Store a matrix inside the environment
NN$weights <- c(1, 3, 3)  # Store a matrix inside the environment
View(NN)
print(NN$weights)  # Before update
update_weights(NN, c(2, 3, 3))  # Pass environment
print(NN$weights)  # After update, value is modified
